<Window x:Class="Prompter.Views.ModeEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Mode"
        Width="480"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="#FFEEEEEE">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Mode Name" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Text="The display name shown in menus and the tray icon." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
            <TextBox x:Name="NameTextBox" Margin="0,0,0,16" Padding="8,6"/>

            <TextBlock Text="System Prompt" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Text="Instructions sent to the AI formatting model." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
        </StackPanel>

        <TextBox x:Name="PromptTextBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16" Padding="8,6"/>

        <StackPanel Grid.Row="2">
            <CheckBox x:Name="SkipFormattingCheckBox" Content="Skip formatting (pass through raw transcription)" Margin="0,0,0,8"/>
            <CheckBox x:Name="ShowDiagnosticCheckBox" Content="Show diagnostic output instead of injecting text" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" Content="Save" Width="90" Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
