<Window x:Class="Prompter.Views.DictionaryEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Dictionary Entry"
        Width="480"
        Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="#FFEEEEEE">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Canonical Word" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Text="The exact spelling you want in the final output." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
            <TextBox x:Name="WordTextBox" Padding="8,6"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Aliases" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Text="Alternate spellings or pronunciations that Whisper might produce." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
            <ListBox x:Name="AliasesListBox" Grid.Row="2" Margin="0,0,0,8"/>
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewAliasTextBox" Grid.Column="0" Padding="8,6" Margin="0,0,8,0"/>
                <Button x:Name="AddAliasButton" Content="Add" Grid.Column="1" Width="80" Margin="0,0,8,0" Click="AddAliasButton_Click"/>
                <Button x:Name="RemoveAliasButton" Content="Remove" Grid.Column="2" Width="80" Click="RemoveAliasButton_Click"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Save" Width="90" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
