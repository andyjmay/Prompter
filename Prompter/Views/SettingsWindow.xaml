<Window x:Class="Prompter.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Prompter.Views"
        Title="Prompter Settings"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="600"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="#FFEEEEEE">

    <Window.Resources>
        <!-- Converters -->
        <local:BoolToTextConverter x:Key="BoolToYesNoConverter" TrueText="Yes" FalseText="No"/>
        <local:BoolToTextConverter x:Key="BoolToActiveConverter" TrueText="Active" FalseText="Inactive"/>
        <local:BoolToBrushConverter x:Key="BoolToColorConverter" TrueBrush="#FF32CD32" FalseBrush="#FFFF4500"/>
        <local:BoolToBrushConverter x:Key="BoolToLoadedColorConverter" TrueBrush="#FF00BFFF" FalseBrush="#FF888888"/>
        <local:BoolToBrushConverter x:Key="BoolToErrorColorConverter" TrueBrush="#FFFF5555" FalseBrush="#FFCCCCCC"/>
        <local:BoolToTextConverter x:Key="BoolToDefaultFlag" TrueText="Default " FalseText=""/>
        <local:BoolToTextConverter x:Key="BoolToSkipFlag" TrueText="Skip " FalseText=""/>
        <local:BoolToTextConverter x:Key="BoolToDebugFlag" TrueText="Debug" FalseText=""/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource SidebarBorderBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="Prompter Settings"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="16,0,16,8"/>
                <Rectangle Height="1"
                           Fill="{DynamicResource SidebarBorderBrush}"
                           Margin="12,0,12,8"/>

                <RadioButton x:Name="GeneralNav"
                             Style="{StaticResource SidebarItemStyle}"
                             GroupName="SettingsNav"
                             IsChecked="True"
                             Checked="Nav_Checked"
                             Tag="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE713;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Width="24"/>
                        <TextBlock Text="General"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="ModesNav"
                             Style="{StaticResource SidebarItemStyle}"
                             GroupName="SettingsNav"
                             Checked="Nav_Checked"
                             Tag="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8D4;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Width="24"/>
                        <TextBlock Text="Modes"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="ModelsNav"
                             Style="{StaticResource SidebarItemStyle}"
                             GroupName="SettingsNav"
                             Checked="Nav_Checked"
                             Tag="2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Width="24"/>
                        <TextBlock Text="Models &amp; Clipboard"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="DictionaryNav"
                             Style="{StaticResource SidebarItemStyle}"
                             GroupName="SettingsNav"
                             Checked="Nav_Checked"
                             Tag="3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE82D;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Width="24"/>
                        <TextBlock Text="Dictionary"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="SnippetsNav"
                             Style="{StaticResource SidebarItemStyle}"
                             GroupName="SettingsNav"
                             Checked="Nav_Checked"
                             Tag="4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Width="24"/>
                        <TextBlock Text="Snippets"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="AppearanceNav"
                             Style="{StaticResource SidebarItemStyle}"
                             GroupName="SettingsNav"
                             Checked="Nav_Checked"
                             Tag="5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE771;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Width="24"/>
                        <TextBlock Text="Appearance"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="LogsNav"
                             Style="{StaticResource SidebarItemStyle}"
                             GroupName="SettingsNav"
                             Checked="Nav_Checked"
                             Tag="6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8FD;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Width="24"/>
                        <TextBlock Text="Logs"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- Right Content Area -->
        <Grid Grid.Column="1" Background="{DynamicResource WindowBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ContentControl x:Name="TabContentHost" Grid.Row="0" Margin="24,24,24,0"/>

            <!-- Bottom Action Bar -->
            <Border Grid.Row="1"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Preview"
                            Style="{StaticResource GhostButtonStyle}"
                            Width="100"
                            Margin="0,0,8,0"
                            Click="Preview_Click"/>
                    <Button Content="Save Options"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="120"
                            Margin="0,0,8,0"
                            Click="Save_Click"/>
                    <Button Content="Cancel"
                            Style="{StaticResource GhostButtonStyle}"
                            Width="100"
                            Click="Cancel_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Hidden Sections Container -->
        <Grid x:Name="SectionsHost" Grid.Column="1" Visibility="Collapsed" Width="0" Height="0">

            <!-- ========================================================= -->
            <!-- SECTION 0: General                                        -->
            <!-- ========================================================= -->
            <Grid x:Name="GeneralSection">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,48">
                        <TextBlock Text="General Settings"
                                   Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Hotkey Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Global Trigger Hotkey"
                                           Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Press and hold this shortcut to begin speaking."
                                           Style="{StaticResource SettingDescriptionStyle}"
                                           Margin="0,0,0,12"/>
                                <Border CornerRadius="6"
                                        Background="#FF1E1E1E"
                                        BorderBrush="#FF3A3A3A"
                                        BorderThickness="1"
                                        Padding="8,6">
                                    <Grid>
                                         <TextBox x:Name="HotkeyTextBox"
                                                  IsReadOnly="True"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  VerticalContentAlignment="Center"
                                                  Foreground="White"
                                                  AutomationProperties.Name="Global trigger hotkey"/>
                                        <Button x:Name="CaptureHotkeyButton"
                                                Content=""
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="CaptureHotkeyButton_Click"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Padding="0"
                                                Cursor="Hand"
                                                ToolTip="Click to capture a new global hotkey"/>
                                    </Grid>
                                </Border>
                                <TextBlock Text="Click to assign a new hotkey."
                                           Style="{StaticResource SettingDescriptionStyle}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Timeout Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Model Idle Timeout (Minutes)"
                                           Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Automatically unload AI models after inactivity."
                                           Style="{StaticResource SettingDescriptionStyle}"
                                           Margin="0,0,0,12"/>
                                <Slider x:Name="TtlSlider"
                                        Minimum="1"
                                        Maximum="30"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        AutoToolTipPlacement="TopLeft"
                                        AutoToolTipPrecision="0"
                                        AutomationProperties.Name="Model idle timeout in minutes"/>
                                <TextBlock x:Name="TtlValue"
                                           Visibility="Visible"
                                           Margin="0,4,0,0"
                                           Foreground="#FFAAAAAA"/>
                            </StackPanel>
                        </Border>

                        <!-- Preference Cards (two columns) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left Card: System & Notifications -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="System &amp; Startup"
                                               Style="{StaticResource CardTitleStyle}"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Launch Prompter on Windows startup"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="AutoStartCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <TextBlock Text="Notifications &amp; Audio"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,8,0,10"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Play audio cues for start/stop dictation"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="AudioFeedbackCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Show system notifications"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="NotificationsCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Show pop-up after text insertion"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="NotifyOnOutputReadyCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Right Card: Text Processing & Cleaning -->
                            <Border Grid.Column="1"
                                    Style="{StaticResource CardStyle}"
                                    Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Text Processing &amp; Cleaning"
                                               Style="{StaticResource CardTitleStyle}"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Replace spoken punctuation"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="SpokenPunctuationCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Format lists (List mode)"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="ListFormattingEnabledCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Clean Mode (Filler Word Removal)"
                                                       Style="{StaticResource SettingLabelStyle}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="Remove filler words. Preserves content."
                                                       Style="{StaticResource SettingDescriptionStyle}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="CleanEnabledCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"
                                                      Checked="CleanEnabledCheckBox_Checked"
                                                      Unchecked="CleanEnabledCheckBox_Checked"/>
                                    </Grid>

                                    <Grid x:Name="CleanPromptGrid" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                         <TextBox x:Name="CleanPromptTextBox"
                                                  Grid.Column="0"
                                                  ToolTip="Custom prompt instructions appended when removing filler words"
                                                  FontSize="11"
                                                  TextWrapping="Wrap"
                                                  Height="80"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Margin="0,0,8,0"
                                                  AutomationProperties.Name="Clean mode prompt"/>
                                        <Button x:Name="ResetCleanPromptButton"
                                                Content="Reset"
                                                Grid.Column="1"
                                                VerticalAlignment="Top"
                                                Padding="8,4"
                                                Click="ResetCleanPromptButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ========================================================= -->
            <!-- SECTION 1: Modes                                          -->
            <!-- ========================================================= -->
            <Grid x:Name="ModesSection">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Text Correction Modes"
                           Style="{StaticResource SectionHeaderStyle}"/>

                <TextBlock Grid.Row="1"
                           Text="Manage how Prompter formats and corrects your speech. Built-in modes can be reset to defaults; custom modes can be deleted."
                           Style="{StaticResource SettingDescriptionStyle}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="ModesListView"
                                  Grid.Row="0"
                                  Margin="0"
                                  BorderThickness="0"
                                  AutomationProperties.Name="Text Correction Modes">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0">
                                            <Border Style="{StaticResource BadgeDefaultStyle}"
                                                    Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="Default"
                                                           Foreground="White"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Style="{StaticResource BadgeSkipStyle}"
                                                    Visibility="{Binding SkipFormatting, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="Skip"
                                                           Foreground="White"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Style="{StaticResource BadgeDebugStyle}"
                                                    Visibility="{Binding ShowDiagnosticOutput, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="Debug"
                                                           Foreground="White"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SystemPrompt}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="#FFCCCCCC"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding SystemPrompt}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="ModesEmptyText"
                                   Grid.Row="0"
                                   Text="No modes configured."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FFBBBBBB"
                                   FontSize="14"
                                   Visibility="Collapsed"/>

                        <Border Grid.Row="1"
                                Padding="12"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="AddModeButton"
                                        Content="+ Add Mode"
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        Click="AddModeButton_Click"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal">
                                    <Button x:Name="SetDefaultModeButton"
                                            Content="Set Default"
                                            Margin="0,0,8,0"
                                            Click="SetDefaultModeButton_Click"/>
                                    <Button x:Name="EditModeButton"
                                            Content="Edit"
                                            Margin="0,0,8,0"
                                            Click="EditModeButton_Click"/>
                                    <Button x:Name="ResetModeButton"
                                            Content="Reset"
                                            Margin="0,0,8,0"
                                            Click="ResetModeButton_Click"/>
                                    <Button x:Name="DeleteModeButton"
                                            Content="Delete"
                                            Click="DeleteModeButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========================================================= -->
            <!-- SECTION 2: Models & Clipboard                             -->
            <!-- ========================================================= -->
            <Grid x:Name="ModelsSection">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Models &amp; Clipboard"
                           Style="{StaticResource SectionHeaderStyle}"/>

                <!-- Model Selectors -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Speech Model (Whisper)"
                                       Style="{StaticResource CardTitleStyle}"/>
                             <ComboBox x:Name="WhisperModelComboBox"
                                       SelectionChanged="WhisperModelComboBox_SelectionChanged"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,0,6"
                                       AutomationProperties.Name="Speech Model"/>
                            <TextBlock x:Name="WhisperModelStatusText"
                                       FontSize="11"
                                       Foreground="#FF32CD32"
                                       Margin="0,0,0,6"
                                       Text=""/>
                            <Button x:Name="ManageCustomModelsButton"
                                    Content="Manage Custom Models..."
                                    Click="ManageCustomModelsButton_Click"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Text Correction Model"
                                           Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="LoadingModelsText"
                                           Text=" (loading...)"
                                           FontStyle="Italic"
                                           Foreground="Gray"
                                           Margin="4,0,0,0"/>
                            </StackPanel>
                             <ComboBox x:Name="ChatModelComboBox"
                                       SelectionChanged="ChatModelComboBox_SelectionChanged"
                                       HorizontalAlignment="Stretch"
                                       Margin="0,0,0,6"
                                       AutomationProperties.Name="Text Correction Model"/>
                             <TextBox x:Name="CustomModelTextBox"
                                      Margin="0,0,0,6"
                                      Visibility="Collapsed"
                                      ToolTip="Enter the exact Foundry Local model alias"
                                      AutomationProperties.Name="Custom model alias"/>
                            <TextBlock x:Name="ChatModelStatusText"
                                       FontSize="11"
                                       Foreground="#FF32CD32"
                                       Margin="0,0,0,6"
                                       Text=""/>
                            <TextBlock Text="Hugging Face Token (Optional)"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"
                                       FontSize="11"
                                       Foreground="#FFBBBBBB"/>
                             <TextBox x:Name="HfTokenTextBox"
                                      ToolTip="Optional token for gated models and higher rate limits on Hugging Face"
                                      FontSize="12"
                                      AutomationProperties.Name="Hugging Face Token"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Sandbox Card -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Model Sandbox &amp; Playground"
                                   Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Open a dedicated sandbox to test transcription, text formatting, edit custom prompts, and analyze generation speeds."
                                   Style="{StaticResource SettingDescriptionStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <Button x:Name="OpenSandboxButton"
                                Content="Open Model Playground..."
                                Click="OpenSandboxButton_Click"
                                HorizontalAlignment="Stretch"
                                Padding="12,8"/>
                    </StackPanel>
                </Border>

                <!-- Clipboard Card -->
                <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Hybrid Keystroke Injection Settings"
                                   Style="{StaticResource CardTitleStyle}"/>
                        <TextBlock Text="Instantly paste long transcriptions using clipboard simulation instead of slow simulated typing."
                                   Style="{StaticResource SettingDescriptionStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton x:Name="UsePasteCheckBox"
                                          Grid.Column="0"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="Enable hybrid clipboard paste"
                                       VerticalAlignment="Center"
                                       Margin="0,0,16,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="Paste threshold (chars):"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox x:Name="PasteThresholdTextBox"
                                     Grid.Column="3"
                                     Width="60"
                                     Text="150"
                                     VerticalAlignment="Center"
                                     HorizontalContentAlignment="Center"
                                     LostFocus="PasteThresholdTextBox_LostFocus"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Model Dashboard -->
                <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Local Model Dashboard"
                                   Style="{StaticResource CardTitleStyle}"
                                   Margin="16,12,16,8"/>

                        <ListView x:Name="ModelsListView"
                                  Grid.Row="1"
                                  Margin="0"
                                  BorderThickness="0"
                                  AutomationProperties.Name="Local Models">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Alias}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TaskType}"
                                                   Foreground="#FFCCCCCC"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SizeDescription}"
                                                   Foreground="#FFCCCCCC"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding IsCached, Converter={StaticResource BoolToYesNoConverter}}"
                                                   Foreground="{Binding IsCached, Converter={StaticResource BoolToColorConverter}}"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding IsLoaded, Converter={StaticResource BoolToActiveConverter}}"
                                                   Foreground="{Binding IsLoaded, Converter={StaticResource BoolToLoadedColorConverter}}"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="ModelsEmptyText"
                                   Grid.Row="1"
                                   Text="No models available."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FFBBBBBB"
                                   FontSize="14"
                                   Visibility="Collapsed"/>

                        <Border Grid.Row="2"
                                Padding="16,12"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,0,12,0">
                                    <Run Text="System: " FontWeight="Bold" Foreground="#FFCCCCCC"/>
                                     <Run x:Name="GpuStatusTextBlock"
                                          Text="DirectML GPU/NPU acceleration active (ONNX Runtime)"
                                          Foreground="#FFAAAAAA"
                                          FontWeight="SemiBold"/>
                                </TextBlock>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal">
                                    <Button x:Name="UnloadModelButton"
                                            Content="Unload Model"
                                            Margin="0,0,8,0"
                                            Click="UnloadModelButton_Click"/>
                                    <Button x:Name="DownloadModelButton"
                                            Content="Download/Cache"
                                            Click="DownloadModelButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========================================================= -->
            <!-- SECTION 3: Dictionary                                     -->
            <!-- ========================================================= -->
            <Grid x:Name="DictionarySection">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Personal Dictionary"
                           Style="{StaticResource SectionHeaderStyle}"/>

                <TextBlock Grid.Row="1"
                           Text="Add words and phrases that Whisper often mishears. Aliases are alternate spellings or pronunciations that should be corrected to the canonical word."
                           Style="{StaticResource SettingDescriptionStyle}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="DictionaryListView"
                                  Grid.Row="0"
                                  Margin="0"
                                  BorderThickness="0"
                                  AutomationProperties.Name="Personal Dictionary">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Word}"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding AliasesDisplay}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="#FFCCCCCC"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="DictionaryEmptyText"
                                   Grid.Row="0"
                                   Text="No entries yet. Click + Add Entry to get started."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FFBBBBBB"
                                   FontSize="14"
                                   Visibility="Collapsed"/>

                        <Border Grid.Row="1"
                                Padding="12"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="AddDictionaryEntryButton"
                                        Content="+ Add Entry"
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        Click="AddDictionaryEntryButton_Click"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal">
                                    <Button x:Name="EditDictionaryEntryButton"
                                            Content="Edit"
                                            Margin="0,0,8,0"
                                            Click="EditDictionaryEntryButton_Click"/>
                                    <Button x:Name="DeleteDictionaryEntryButton"
                                            Content="Delete"
                                            Click="DeleteDictionaryEntryButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========================================================= -->
            <!-- SECTION 4: Snippets                                       -->
            <!-- ========================================================= -->
            <Grid x:Name="SnippetsSection">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Text Snippets"
                           Style="{StaticResource SectionHeaderStyle}"/>

                <TextBlock Grid.Row="1"
                           Text="Voice-activated macros that insert pre-written text. Speak the trigger phrase and the expansion is typed directly."
                           Style="{StaticResource SettingDescriptionStyle}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="SnippetsListView"
                                  Grid.Row="0"
                                  Margin="0"
                                  BorderThickness="0"
                                  AutomationProperties.Name="Text Snippets">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Trigger}"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ExpansionPreview}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="#FFCCCCCC"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="SnippetsEmptyText"
                                   Grid.Row="0"
                                   Text="No snippets yet. Click + Add Snippet to get started."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FFBBBBBB"
                                   FontSize="14"
                                   Visibility="Collapsed"/>

                        <Border Grid.Row="1"
                                Padding="12"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="AddSnippetButton"
                                        Content="+ Add Snippet"
                                        Grid.Column="0"
                                        HorizontalAlignment="Left"
                                        Click="AddSnippetButton_Click"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal">
                                    <Button x:Name="EditSnippetButton"
                                            Content="Edit"
                                            Margin="0,0,8,0"
                                            Click="EditSnippetButton_Click"/>
                                    <Button x:Name="DeleteSnippetButton"
                                            Content="Delete"
                                            Click="DeleteSnippetButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========================================================= -->
            <!-- SECTION 5: Appearance                                     -->
            <!-- ========================================================= -->
            <Grid x:Name="AppearanceSection">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,0,48">
                        <TextBlock Text="Appearance &amp; Overlays"
                                   Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Overlay + Toast Cards -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Recording Overlay"
                                               Style="{StaticResource CardTitleStyle}"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Show recording overlay while listening"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="ShowRecordingOverlayCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Show status text on recording overlay"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="ShowStatusTextCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Listening label"
                                                       FontSize="11"
                                                       Foreground="#FFBBBBBB"
                                                       Margin="0,0,0,4"/>
                                             <TextBox x:Name="ListeningLabelTextBox"
                                                      VerticalContentAlignment="Center"
                                                      AutomationProperties.Name="Listening label"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Processing label"
                                                       FontSize="11"
                                                       Foreground="#FFBBBBBB"
                                                       Margin="0,0,0,4"/>
                                             <TextBox x:Name="ProcessingLabelTextBox"
                                                      VerticalContentAlignment="Center"
                                                      AutomationProperties.Name="Processing label"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Show audio level meter on recording overlay"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="ShowAudioMeterCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Anchor"
                                                       FontSize="11"
                                                       Foreground="#FFBBBBBB"
                                                       Margin="0,0,0,4"/>
                                             <ComboBox x:Name="RecordingAnchorComboBox" AutomationProperties.Name="Recording overlay anchor"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                            <TextBlock Text="Offset X (px)"
                                                       FontSize="11"
                                                       Foreground="#FFBBBBBB"
                                                       Margin="0,0,0,4"/>
                                         <TextBox x:Name="RecordingOffsetXTextBox"
                                                  HorizontalContentAlignment="Center"
                                                  LostFocus="OffsetTextBox_LostFocus"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Offset Y (px)"
                                                       FontSize="11"
                                                       Foreground="#FFBBBBBB"
                                                       Margin="0,0,0,4"/>
                                         <TextBox x:Name="RecordingOffsetYTextBox"
                                                  HorizontalContentAlignment="Center"
                                                  LostFocus="OffsetTextBox_LostFocus"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Preview Toast"
                                               Style="{StaticResource CardTitleStyle}"/>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Show preview toast after transcription"
                                                   Style="{StaticResource SettingLabelStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="ShowPreviewToastCheckBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ToggleSwitchStyle}"
                                                      VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Anchor"
                                                       FontSize="11"
                                                       Foreground="#FFBBBBBB"
                                                       Margin="0,0,0,4"/>
                                             <ComboBox x:Name="PreviewAnchorComboBox" AutomationProperties.Name="Preview toast anchor"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                            <TextBlock Text="Offset X (px)"
                                                       FontSize="11"
                                                       Foreground="#FFBBBBBB"
                                                       Margin="0,0,0,4"/>
                                         <TextBox x:Name="PreviewOffsetXTextBox"
                                                  HorizontalContentAlignment="Center"
                                                  LostFocus="OffsetTextBox_LostFocus"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Offset Y (px)"
                                                       FontSize="11"
                                                       Foreground="#FFBBBBBB"
                                                       Margin="0,0,0,4"/>
                                         <TextBox x:Name="PreviewOffsetYTextBox"
                                                  HorizontalContentAlignment="Center"
                                                  LostFocus="OffsetTextBox_LostFocus"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Dismiss after (seconds): "
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <Slider x:Name="ToastDurationSlider"
                                                Grid.Column="1"
                                                Minimum="1"
                                                Maximum="15"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                AutoToolTipPlacement="TopLeft"
                                                AutoToolTipPrecision="0"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ToastDurationValue"
                                                   Grid.Column="2"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="#FF00BFFF"
                                                   FontSize="14"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max width (px): "
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <Slider x:Name="MaxWidthSlider"
                                                Grid.Column="1"
                                                Minimum="300"
                                                Maximum="800"
                                                TickFrequency="50"
                                                IsSnapToTickEnabled="True"
                                                AutoToolTipPlacement="TopLeft"
                                                AutoToolTipPrecision="0"
                                                VerticalAlignment="Center"/>
                                        <TextBlock x:Name="MaxWidthValue"
                                                   Grid.Column="2"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="#FF00BFFF"
                                                   FontSize="14"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Colors Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Colors"
                                           Style="{StaticResource CardTitleStyle}"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Theme"
                                                   FontSize="11"
                                                   Foreground="#FFBBBBBB"
                                                   Margin="0,0,0,4"/>
                                         <ComboBox x:Name="ThemeComboBox" AutomationProperties.Name="Theme"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Accent Color (hex)"
                                                   FontSize="11"
                                                   Foreground="#FFBBBBBB"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="AccentColorTextBox"
                                                     Grid.Column="0"
                                                     VerticalContentAlignment="Center"
                                                     Text="#FF3333"/>
                                            <Border x:Name="AccentPreview"
                                                    Grid.Column="1"
                                                    Width="24"
                                                    Height="24"
                                                    CornerRadius="4"
                                                    Margin="8,0,0,0"
                                                    BorderBrush="#FF555555"
                                                    BorderThickness="1"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Text Color (hex)"
                                                   FontSize="11"
                                                   Foreground="#FFBBBBBB"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="TextColorTextBox"
                                                     Grid.Column="0"
                                                     VerticalContentAlignment="Center"/>
                                            <Border x:Name="TextColorPreview"
                                                    Grid.Column="1"
                                                    Width="24"
                                                    Height="24"
                                                    CornerRadius="4"
                                                    Margin="8,0,0,0"
                                                    BorderBrush="#FF555555"
                                                    BorderThickness="1"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Processing Accent (hex)"
                                                   FontSize="11"
                                                   Foreground="#FFBBBBBB"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ProcessingAccentColorTextBox"
                                                     Grid.Column="0"
                                                     VerticalContentAlignment="Center"/>
                                            <Border x:Name="ProcessingAccentPreview"
                                                    Grid.Column="1"
                                                    Width="24"
                                                    Height="24"
                                                    CornerRadius="4"
                                                    Margin="8,0,0,0"
                                                    BorderBrush="#FF555555"
                                                    BorderThickness="1"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Overlay Background (hex)"
                                                   FontSize="11"
                                                   Foreground="#FFBBBBBB"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="OverlayBackgroundColorTextBox"
                                                     Grid.Column="0"
                                                     VerticalContentAlignment="Center"/>
                                            <Border x:Name="OverlayBackgroundPreview"
                                                    Grid.Column="1"
                                                    Width="24"
                                                    Height="24"
                                                    CornerRadius="4"
                                                    Margin="8,0,0,0"
                                                    BorderBrush="#FF555555"
                                                    BorderThickness="1"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Toast Background (hex)"
                                                   FontSize="11"
                                                   Foreground="#FFBBBBBB"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ToastBackgroundColorTextBox"
                                                     Grid.Column="0"
                                                     VerticalContentAlignment="Center"/>
                                            <Border x:Name="ToastBackgroundPreview"
                                                    Grid.Column="1"
                                                    Width="24"
                                                    Height="24"
                                                    CornerRadius="4"
                                                    Margin="8,0,0,0"
                                                    BorderBrush="#FF555555"
                                                    BorderThickness="1"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Typography Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Typography"
                                           Style="{StaticResource CardTitleStyle}"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Font Family"
                                                   FontSize="11"
                                                   Foreground="#FFBBBBBB"
                                                   Margin="0,0,0,4"/>
                                         <ComboBox x:Name="FontFamilyComboBox" IsEditable="True" LostFocus="FontFamilyComboBox_LostFocus" AutomationProperties.Name="Font Family"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Overlay font size: "
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <Slider x:Name="OverlayFontSizeSlider"
                                            Grid.Column="1"
                                            Minimum="8"
                                            Maximum="48"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            AutoToolTipPlacement="TopLeft"
                                            AutoToolTipPrecision="0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="OverlayFontSizeValue"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="#FF00BFFF"
                                               FontSize="14"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Toast title size: "
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <Slider x:Name="ToastTitleFontSizeSlider"
                                            Grid.Column="1"
                                            Minimum="8"
                                            Maximum="48"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            AutoToolTipPlacement="TopLeft"
                                            AutoToolTipPrecision="0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ToastTitleFontSizeValue"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="#FF00BFFF"
                                               FontSize="14"/>
                                </Grid>
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Toast body size: "
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <Slider x:Name="ToastBodyFontSizeSlider"
                                            Grid.Column="1"
                                            Minimum="8"
                                            Maximum="48"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            AutoToolTipPlacement="TopLeft"
                                            AutoToolTipPrecision="0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ToastBodyFontSizeValue"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="#FF00BFFF"
                                               FontSize="14"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Shape & Effects Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Shape &amp; Effects"
                                           Style="{StaticResource CardTitleStyle}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Overlay opacity: "
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <Slider x:Name="OpacitySlider"
                                            Grid.Column="1"
                                            Minimum="0"
                                            Maximum="100"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            AutoToolTipPlacement="TopLeft"
                                            AutoToolTipPrecision="0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="OpacityValue"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="#FF00BFFF"
                                               FontSize="14"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Toast opacity: "
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <Slider x:Name="ToastOpacitySlider"
                                            Grid.Column="1"
                                            Minimum="0"
                                            Maximum="100"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            AutoToolTipPlacement="TopLeft"
                                            AutoToolTipPrecision="0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ToastOpacityValue"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="#FF00BFFF"
                                               FontSize="14"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Corner radius: "
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <Slider x:Name="CornerRadiusSlider"
                                            Grid.Column="1"
                                            Minimum="0"
                                            Maximum="32"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            AutoToolTipPlacement="TopLeft"
                                            AutoToolTipPrecision="0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="CornerRadiusValue"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="#FF00BFFF"
                                               FontSize="14"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Padding: "
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <Slider x:Name="PaddingSlider"
                                            Grid.Column="1"
                                            Minimum="0"
                                            Maximum="32"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            AutoToolTipPlacement="TopLeft"
                                            AutoToolTipPrecision="0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PaddingValue"
                                               Grid.Column="2"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               Foreground="#FF00BFFF"
                                               FontSize="14"/>
                                </Grid>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Show window shadow"
                                               Style="{StaticResource SettingLabelStyle}"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton x:Name="ShadowEnabledCheckBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Pulse Speed"
                                                   FontSize="11"
                                                   Foreground="#FFBBBBBB"
                                                   Margin="0,0,0,4"/>
                                         <ComboBox x:Name="PulseSpeedComboBox" AutomationProperties.Name="Pulse speed"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Visual Preview Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Visual Preview"
                                           Style="{StaticResource CardTitleStyle}"
                                           Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="RecordingMockup"
                                            Grid.Column="0"
                                            MinHeight="48"
                                            BorderThickness="1"
                                            Margin="0,0,8,0"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel x:Name="RecordingMockupStack"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Ellipse x:Name="RecordingMockupDot"
                                                     Width="10"
                                                     Height="10"
                                                     Margin="0,0,8,0"/>
                                            <TextBlock x:Name="RecordingMockupText"
                                                       Text="Listening..."
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="ToastMockup"
                                            Grid.Column="1"
                                            MinHeight="48"
                                            BorderThickness="1"
                                            HorizontalAlignment="Stretch">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock x:Name="ToastMockupTitle"
                                                       Text="Prompter Output"
                                                       FontWeight="Bold"
                                                       Grid.Row="0"
                                                       Margin="0,0,0,2"/>
                                            <TextBlock x:Name="ToastMockupBody"
                                                       Text="Preview text here..."
                                                       TextTrimming="CharacterEllipsis"
                                                       Grid.Row="1"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ========================================================= -->
            <!-- SECTION 6: Logs                                           -->
            <!-- ========================================================= -->
            <Grid x:Name="LogsSection">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Logs"
                           Style="{StaticResource SectionHeaderStyle}"/>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="12"
                                BorderBrush="{DynamicResource SidebarBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Filter Logs"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                 <TextBox x:Name="LogsFilterTextBox"
                                          Grid.Column="1"
                                          Padding="8,6"
                                          TextChanged="LogsFilterTextBox_TextChanged"
                                          VerticalContentAlignment="Center"
                                          AutomationProperties.Name="Filter logs"/>
                                <Button x:Name="ClearLogsButton"
                                        Grid.Column="2"
                                        Content="Clear Logs"
                                        VerticalAlignment="Center"
                                        Margin="12,0,0,0"
                                        Click="ClearLogsButton_Click"/>
                            </Grid>
                        </Border>

                        <ListView x:Name="LogsListView"
                                  Grid.Row="1"
                                  Margin="0"
                                  BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  AutomationProperties.Name="Application Logs">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="8,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss.fff}}"
                                                   Foreground="#FFCCCCCC"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{Binding IsError, Converter={StaticResource BoolToErrorColorConverter}}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SourceFile}"
                                                   Foreground="#FF888888"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock x:Name="LogsEmptyText"
                                   Grid.Row="1"
                                   Text="No log entries to display."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#FFBBBBBB"
                                   FontSize="14"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
