<Window x:Class="Prompter.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Prompter.Views"
        Title="Prompter Settings"
        Width="580"
        Height="760"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="#FFEEEEEE">
    
    <Window.Resources>
        <!-- Converters -->
        <local:BoolToTextConverter x:Key="BoolToYesNoConverter" TrueText="Yes" FalseText="No"/>
        <local:BoolToTextConverter x:Key="BoolToActiveConverter" TrueText="Active" FalseText="No"/>
        <local:BoolToBrushConverter x:Key="BoolToColorConverter" TrueBrush="#FF32CD32" FalseBrush="#FFFF4500"/>
        <local:BoolToBrushConverter x:Key="BoolToLoadedColorConverter" TrueBrush="#FF00BFFF" FalseBrush="#FF888888"/>
        <local:BoolToBrushConverter x:Key="BoolToErrorColorConverter" TrueBrush="#FFFF5555" FalseBrush="#FFCCCCCC"/>
        <local:BoolToTextConverter x:Key="BoolToDefaultFlag" TrueText="Default " FalseText=""/>
        <local:BoolToTextConverter x:Key="BoolToSkipFlag" TrueText="Skip " FalseText=""/>
        <local:BoolToTextConverter x:Key="BoolToDebugFlag" TrueText="Debug" FalseText=""/>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Main Tabbed UI -->
        <TabControl Grid.Row="0">
            <!-- TAB 1: General Options -->
            <TabItem Header="General Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,12,0">
                        <TextBlock Text="Global Trigger Hotkey" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock Text="Press and hold this shortcut to begin speaking." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HotkeyTextBox" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,12,0" Padding="8,8"/>
                            <Button x:Name="CaptureHotkeyButton" Content="Press to Record" Grid.Column="1" Width="140" Click="CaptureHotkeyButton_Click"/>
                        </Grid>

                        <TextBlock Text="Model Idle Timeout (Minutes)" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock Text="AI models will unload automatically after inactivity to free system resources." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="TtlSlider" Minimum="1" Maximum="30" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TtlValue" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>

                        <TextBlock Text="Application Preferences" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                        <CheckBox x:Name="AutoStartCheckBox" Content="Launch Prompter on Windows startup"/>
                        <CheckBox x:Name="AudioFeedbackCheckBox" Content="Play audio feedback sounds when starting/stopping dictation"/>
                        <CheckBox x:Name="NotificationsCheckBox" Content="Show Windows balloon notifications for status updates"/>
                        <CheckBox x:Name="NotifyOnOutputReadyCheckBox" Content="Show notification popup after text is inserted" Margin="0,0,0,12"/>
                        <CheckBox x:Name="SpokenPunctuationCheckBox" Content="Replace spoken punctuation commands (comma, period, etc.)" Margin="0,0,0,10"/>
                        <CheckBox x:Name="CleanEnabledCheckBox" Content="Remove filler words (Clean mode)" Margin="0,0,0,6" Checked="CleanEnabledCheckBox_Checked" Unchecked="CleanEnabledCheckBox_Checked"/>
                        <Grid x:Name="CleanPromptGrid" Margin="24,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CleanPromptTextBox" Grid.Column="0" ToolTip="Custom prompt instructions appended when removing filler words" FontSize="11" TextWrapping="Wrap" Height="40" VerticalScrollBarVisibility="Auto" Margin="0,0,8,0"/>
                            <Button x:Name="ResetCleanPromptButton" Content="Reset" Grid.Column="1" VerticalAlignment="Top" Padding="8,4" Click="ResetCleanPromptButton_Click"/>
                        </Grid>
                        <CheckBox x:Name="ListFormattingEnabledCheckBox" Content="Format lists (List mode)" Margin="0,0,0,10"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 2: Modes -->
            <TabItem Header="Modes">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Text Correction Modes" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" Text="Manage how Prompter formats and corrects your speech. Built-in modes can be reset to defaults; custom modes can be deleted." FontSize="11" Foreground="#FF888888" Margin="0,22,0,8" TextWrapping="Wrap"/>

                    <ListView x:Name="ModesListView" Grid.Row="1" Margin="0,0,0,12">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="White"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Prompt" Width="260">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SystemPrompt}" TextTrimming="CharacterEllipsis" Foreground="#FFCCCCCC"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Flags" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding IsDefault, Converter={StaticResource BoolToDefaultFlag}}" Foreground="#FF00BFFF" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding SkipFormatting, Converter={StaticResource BoolToSkipFlag}}" Foreground="#FFFFA500" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding ShowDiagnosticOutput, Converter={StaticResource BoolToDebugFlag}}" Foreground="#FF888888" FontWeight="Bold"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="AddModeButton" Content="+ Add Mode" Grid.Column="0" HorizontalAlignment="Left" Click="AddModeButton_Click"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="SetDefaultModeButton" Content="Set Default" Margin="0,0,8,0" Click="SetDefaultModeButton_Click"/>
                            <Button x:Name="EditModeButton" Content="Edit" Margin="0,0,8,0" Click="EditModeButton_Click"/>
                            <Button x:Name="ResetModeButton" Content="Reset" Margin="0,0,8,0" Click="ResetModeButton_Click"/>
                            <Button x:Name="DeleteModeButton" Content="Delete" Click="DeleteModeButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 3: Dictionary -->
            <TabItem Header="Dictionary">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Personal Dictionary" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" Text="Add words and phrases that Whisper often mishears. Aliases are alternate spellings or pronunciations that should be corrected to the canonical word." FontSize="11" Foreground="#FF888888" Margin="0,22,0,8" TextWrapping="Wrap"/>

                    <ListView x:Name="DictionaryListView" Grid.Row="1" Margin="0,0,0,12">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Word" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Word}" FontWeight="SemiBold" Foreground="White"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Aliases" Width="320">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding AliasesDisplay}" TextTrimming="CharacterEllipsis" Foreground="#FFCCCCCC"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="AddDictionaryEntryButton" Content="+ Add Entry" Grid.Column="0" HorizontalAlignment="Left" Click="AddDictionaryEntryButton_Click"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="EditDictionaryEntryButton" Content="Edit" Margin="0,0,8,0" Click="EditDictionaryEntryButton_Click"/>
                            <Button x:Name="DeleteDictionaryEntryButton" Content="Delete" Click="DeleteDictionaryEntryButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 4: Snippets -->
            <TabItem Header="Snippets">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Text Snippets" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock Grid.Row="0" Text="Voice-activated macros that insert pre-written text. Speak the trigger phrase and the expansion is typed directly." FontSize="11" Foreground="#FF888888" Margin="0,22,0,8" TextWrapping="Wrap"/>

                    <ListView x:Name="SnippetsListView" Grid.Row="1" Margin="0,0,0,12">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Trigger" Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Trigger}" FontWeight="SemiBold" Foreground="White"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Expansion" Width="320">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ExpansionPreview}" TextTrimming="CharacterEllipsis" Foreground="#FFCCCCCC"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="AddSnippetButton" Content="+ Add Snippet" Grid.Column="0" HorizontalAlignment="Left" Click="AddSnippetButton_Click"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="EditSnippetButton" Content="Edit" Margin="0,0,8,0" Click="EditSnippetButton_Click"/>
                            <Button x:Name="DeleteSnippetButton" Content="Delete" Click="DeleteSnippetButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 5: AI Models & Paste Settings -->
            <TabItem Header="Models &amp; Clipboard">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Whisper and Chat Model Selectors -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Text="Speech Model (Whisper)" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                            <ComboBox x:Name="WhisperModelComboBox" SelectionChanged="WhisperModelComboBox_SelectionChanged" HorizontalAlignment="Stretch"/>
                            <TextBlock x:Name="WhisperModelStatusText" FontSize="11" Foreground="#FF32CD32" Margin="0,4,0,0" Text=""/>
                            <Button x:Name="ManageCustomModelsButton" Content="Manage Custom Models..." Margin="0,8,0,0" Click="ManageCustomModelsButton_Click" HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Text Correction Model" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="LoadingModelsText" Text=" (loading…)" FontStyle="Italic" Foreground="Gray" Margin="4,0,0,0"/>
                            </StackPanel>
                            <ComboBox x:Name="ChatModelComboBox" SelectionChanged="ChatModelComboBox_SelectionChanged" HorizontalAlignment="Stretch"/>
                            <TextBox x:Name="CustomModelTextBox" Margin="0,6,0,0" Visibility="Collapsed" ToolTip="Enter the exact Foundry Local model alias"/>
                            <TextBlock x:Name="ChatModelStatusText" FontSize="11" Foreground="#FF32CD32" Margin="0,4,0,0" Text=""/>
                            <TextBlock Text="Hugging Face Token (Optional)" FontWeight="SemiBold" Margin="0,10,0,4" FontSize="11" Foreground="#FF888888"/>
                            <TextBox x:Name="HfTokenTextBox" ToolTip="Optional token for gated models and higher rate limits on Hugging Face" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Model Sandbox Playground -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,16">
                        <TextBlock Text="Model Sandbox &amp; Playground" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock Text="Open a dedicated sandbox to test transcription, text formatting, edit custom prompts, and analyze generation speeds." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
                        <Button x:Name="OpenSandboxButton" Content="Open Model Playground..." Click="OpenSandboxButton_Click" HorizontalAlignment="Stretch" Padding="12,8"/>
                    </StackPanel>


                    <!-- Clipboard Paste Threshold Settings -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,20">
                        <TextBlock Text="Hybrid Keystroke Injection Settings" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock Text="Instantly paste long transcriptions using clipboard simulation instead of slow simulated typing." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="UsePasteCheckBox" Content="Enable hybrid clipboard paste" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="Paste threshold (characters): " VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="PasteThresholdTextBox" Width="60" Text="150" VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Model Status List -->
                    <TextBlock Grid.Row="3" Text="Local Model Dashboard" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,6"/>
                    <ListView x:Name="ModelsListView" Grid.Row="4" Margin="0,0,0,12" GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Model Alias" Width="140" DisplayMemberBinding="{Binding Alias}"/>
                                <GridViewColumn Header="Type" Width="130" DisplayMemberBinding="{Binding TaskType}"/>
                                <GridViewColumn Header="Size" Width="70" DisplayMemberBinding="{Binding SizeDescription}"/>
                                <GridViewColumn Header="Downloaded" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsCached, Converter={StaticResource BoolToYesNoConverter}}" 
                                                       Foreground="{Binding IsCached, Converter={StaticResource BoolToColorConverter}}" 
                                                       FontWeight="Bold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Loaded" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsLoaded, Converter={StaticResource BoolToActiveConverter}}" 
                                                       Foreground="{Binding IsLoaded, Converter={StaticResource BoolToLoadedColorConverter}}" 
                                                       FontWeight="Bold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Management Actions -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0">
                            <Run Text="System: " FontWeight="Bold" Foreground="#FFCCCCCC"/>
                            <Run x:Name="GpuStatusTextBlock" Text="DirectML GPU/NPU acceleration active (ONNX Runtime)" Foreground="#FF32CD32" FontWeight="SemiBold"/>
                        </TextBlock>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="UnloadModelButton" Content="Unload Model" Margin="0,0,8,0" Click="UnloadModelButton_Click"/>
                            <Button x:Name="DownloadModelButton" Content="Download/Cache" Click="DownloadModelButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 6: Appearance & Overlays -->
            <TabItem Header="Appearance">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,12,0">

                        <!-- Recording Overlay -->
                        <TextBlock Text="Recording Overlay" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <CheckBox x:Name="ShowRecordingOverlayCheckBox" Content="Show recording overlay while listening" Margin="0,0,0,8"/>
                        <CheckBox x:Name="ShowStatusTextCheckBox" Content="Show status text on recording overlay" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Listening label" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="ListeningLabelTextBox" VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Processing label" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="ProcessingLabelTextBox" VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <CheckBox x:Name="ShowAudioMeterCheckBox" Content="Show audio level meter on recording overlay" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Anchor" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <ComboBox x:Name="RecordingAnchorComboBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Offset X (px)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="RecordingOffsetXTextBox" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Offset Y (px)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="RecordingOffsetYTextBox" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Preview Toast -->
                        <TextBlock Text="Preview Toast" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <CheckBox x:Name="ShowPreviewToastCheckBox" Content="Show preview toast after transcription" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Anchor" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <ComboBox x:Name="PreviewAnchorComboBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Offset X (px)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="PreviewOffsetXTextBox" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Offset Y (px)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBox x:Name="PreviewOffsetYTextBox" HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Dismiss after (seconds): " VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="ToastDurationSlider" Grid.Column="1" Minimum="1" Maximum="15" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ToastDurationValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Max width (px): " VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="MaxWidthSlider" Grid.Column="1" Minimum="300" Maximum="800" TickFrequency="50" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MaxWidthValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>

                        <!-- Colors -->
                        <TextBlock Text="Colors" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Theme" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <ComboBox x:Name="ThemeComboBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Accent Color (hex)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="AccentColorTextBox" Grid.Column="0" VerticalContentAlignment="Center" Text="#FF3333"/>
                                    <Border x:Name="AccentPreview" Grid.Column="1" Width="24" Height="24" CornerRadius="4" Margin="8,0,0,0" BorderBrush="#FF555555" BorderThickness="1"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Text Color (hex)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TextColorTextBox" Grid.Column="0" VerticalContentAlignment="Center"/>
                                    <Border x:Name="TextColorPreview" Grid.Column="1" Width="24" Height="24" CornerRadius="4" Margin="8,0,0,0" BorderBrush="#FF555555" BorderThickness="1"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Processing Accent (hex)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ProcessingAccentColorTextBox" Grid.Column="0" VerticalContentAlignment="Center"/>
                                    <Border x:Name="ProcessingAccentPreview" Grid.Column="1" Width="24" Height="24" CornerRadius="4" Margin="8,0,0,0" BorderBrush="#FF555555" BorderThickness="1"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Overlay Background (hex)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="OverlayBackgroundColorTextBox" Grid.Column="0" VerticalContentAlignment="Center"/>
                                    <Border x:Name="OverlayBackgroundPreview" Grid.Column="1" Width="24" Height="24" CornerRadius="4" Margin="8,0,0,0" BorderBrush="#FF555555" BorderThickness="1"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Toast Background (hex)" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ToastBackgroundColorTextBox" Grid.Column="0" VerticalContentAlignment="Center"/>
                                    <Border x:Name="ToastBackgroundPreview" Grid.Column="1" Width="24" Height="24" CornerRadius="4" Margin="8,0,0,0" BorderBrush="#FF555555" BorderThickness="1"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Typography -->
                        <TextBlock Text="Typography" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Font Family" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <ComboBox x:Name="FontFamilyComboBox" IsEditable="True"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Overlay font size: " VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="OverlayFontSizeSlider" Grid.Column="1" Minimum="8" Maximum="48" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="OverlayFontSizeValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Toast title size: " VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="ToastTitleFontSizeSlider" Grid.Column="1" Minimum="8" Maximum="48" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ToastTitleFontSizeValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Toast body size: " VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="ToastBodyFontSizeSlider" Grid.Column="1" Minimum="8" Maximum="48" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ToastBodyFontSizeValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>

                        <!-- Shape & Effects -->
                        <TextBlock Text="Shape &amp; Effects" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Overlay opacity: " VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="OpacitySlider" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="OpacityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Toast opacity: " VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="ToastOpacitySlider" Grid.Column="1" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ToastOpacityValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Corner radius: " VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="CornerRadiusSlider" Grid.Column="1" Minimum="0" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CornerRadiusValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Padding: " VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Slider x:Name="PaddingSlider" Grid.Column="1" Minimum="0" Maximum="32" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PaddingValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="14"/>
                        </Grid>
                        <CheckBox x:Name="ShadowEnabledCheckBox" Content="Show window shadow" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Pulse Speed" FontSize="11" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <ComboBox x:Name="PulseSpeedComboBox"/>
                            </StackPanel>
                        </Grid>

                        <!-- Visual Preview -->
                        <TextBlock Text="Visual Preview" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="RecordingMockup" Grid.Column="0" MinHeight="48" BorderThickness="1" Margin="0,0,8,0" HorizontalAlignment="Stretch">
                                <StackPanel x:Name="RecordingMockupStack" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse x:Name="RecordingMockupDot" Width="10" Height="10" Margin="0,0,8,0"/>
                                    <TextBlock x:Name="RecordingMockupText" Text="Listening..." FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ToastMockup" Grid.Column="1" MinHeight="48" BorderThickness="1" HorizontalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="ToastMockupTitle" Text="Prompter Output" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="ToastMockupBody" Text="Preview text here..." TextTrimming="CharacterEllipsis" Grid.Row="1"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- TAB 7: Logs -->
            <TabItem Header="Logs">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Filter Logs" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                            <TextBox x:Name="LogsFilterTextBox" Padding="8,6" TextChanged="LogsFilterTextBox_TextChanged"/>
                        </StackPanel>
                        <Button x:Name="ClearLogsButton" Grid.Column="1" Content="Clear Logs" VerticalAlignment="Bottom" Click="ClearLogsButton_Click"/>
                    </Grid>

                    <ListView x:Name="LogsListView" Grid.Row="1" Margin="0,0,0,12">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Timestamp" Width="140" DisplayMemberBinding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss.fff}}"/>
                                <GridViewColumn Header="Message" Width="360">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="{Binding IsError, Converter={StaticResource BoolToErrorColorConverter}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="File" Width="100" DisplayMemberBinding="{Binding SourceFile}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Dialog Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Preview" Width="100" Margin="0,0,8,0" Click="Preview_Click"/>
            <Button Content="Save Options" Width="120" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="100" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
