<Window x:Class="Prompter.Views.ModelTestingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Prompter.Views"
        Title="Model Evaluation Sandbox"
        Width="1100"
        Height="760"
        MinWidth="950"
        MinHeight="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="#FFEEEEEE">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Column 0: History Sidebar -->
            <ColumnDefinition Width="280" MinWidth="200"/>
            <!-- Column 1: Splitter 1 -->
            <ColumnDefinition Width="Auto"/>
            <!-- Column 2: Config & Input Panel -->
            <ColumnDefinition Width="1*" MinWidth="300"/>
            <!-- Column 3: Splitter 2 -->
            <ColumnDefinition Width="Auto"/>
            <!-- Column 4: Outputs & Performance -->
            <ColumnDefinition Width="1.2*" MinWidth="350"/>
        </Grid.ColumnDefinitions>

        <!-- TOP HEADER: Wizard Stepper Progress -->
        <Border Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,0,1" Padding="16,12" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Model Sandbox &amp; Evaluation" FontWeight="Bold" Foreground="White" FontSize="18"/>
                    <TextBlock Text="Benchmark speed, quality, and prompt formatting logic locally" FontSize="11" Foreground="#FF888888" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Stepper Progress Bar -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <!-- Step 1 -->
                    <Border x:Name="Step1Badge" Width="20" Height="20" CornerRadius="10" Background="#FF00BFFF" Margin="0,0,6,0">
                        <TextBlock x:Name="Step1BadgeText" Text="1" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step1Text" Text="Select Models" FontWeight="SemiBold" Foreground="#FF00BFFF" VerticalAlignment="Center"/>

                    <!-- Line 1-2 -->
                    <Line x:Name="StepLine1" X1="0" Y1="10" X2="20" Y2="10" Stroke="#FF444444" StrokeThickness="2" Margin="8,0" SnapsToDevicePixels="True"/>

                    <!-- Step 2 -->
                    <Border x:Name="Step2Badge" Width="20" Height="20" CornerRadius="10" Background="#FF2D2D2D" Margin="0,0,6,0">
                        <TextBlock x:Name="Step2BadgeText" Text="2" Foreground="#FFAAAAAA" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step2Text" Text="Provide Input" Foreground="#FF888888" VerticalAlignment="Center"/>

                    <!-- Line 2-3 -->
                    <Line x:Name="StepLine2" X1="0" Y1="10" X2="20" Y2="10" Stroke="#FF444444" StrokeThickness="2" Margin="8,0" SnapsToDevicePixels="True"/>

                    <!-- Step 3 -->
                    <Border x:Name="Step3Badge" Width="20" Height="20" CornerRadius="10" Background="#FF2D2D2D" Margin="0,0,6,0">
                        <TextBlock x:Name="Step3BadgeText" Text="3" Foreground="#FFAAAAAA" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step3Text" Text="Run Pipeline" Foreground="#FF888888" VerticalAlignment="Center"/>

                    <!-- Line 3-4 -->
                    <Line x:Name="StepLine3" X1="0" Y1="10" X2="20" Y2="10" Stroke="#FF444444" StrokeThickness="2" Margin="8,0" SnapsToDevicePixels="True"/>

                    <!-- Step 4 -->
                    <Border x:Name="Step4Badge" Width="20" Height="20" CornerRadius="10" Background="#FF2D2D2D" Margin="0,0,6,0">
                        <TextBlock x:Name="Step4BadgeText" Text="4" Foreground="#FFAAAAAA" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step4Text" Text="Analyze Results" Foreground="#FF888888" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LEFT SIDEBAR: History -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="TEST RUN HISTORY" FontWeight="Bold" Foreground="#FF666666" FontSize="11" Margin="0,0,0,4"/>
                    <TextBlock Text="Select two items to compare side-by-side" FontSize="10" Foreground="#FF888888"/>
                </StackPanel>

                <ListView x:Name="HistoryListView" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,12" SelectionMode="Single" SelectionChanged="HistoryListView_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="8"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="#FF252525"
                                                BorderThickness="0,0,0,1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FF222222"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FF2A2A2A"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="#FF00BFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <CheckBox IsChecked="{Binding IsCompareTarget}" Checked="CompareCheckBox_Changed" Unchecked="CompareCheckBox_Changed" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <Grid>
                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis" Width="180" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding SpeedLabel}" Foreground="#FF00BFFF" FontWeight="Bold" HorizontalAlignment="Right" FontSize="11"/>
                                    </Grid>
                                    <TextBlock Text="{Binding ConfigSummary}" FontSize="10" Foreground="#FF888888" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding PreviewText}" FontSize="11" Foreground="#FFCCCCCC" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="CompareButton" Grid.Column="0" Content="Compare (0/2)" Click="CompareButton_Click" IsEnabled="False" Margin="0,0,4,0"/>
                    <Button x:Name="ClearHistoryButton" Grid.Column="1" Content="Clear" Click="ClearHistoryButton_Click" Margin="4,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Splitter between History and Center -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#FF333333" Margin="0,16"/>

        <!-- CENTER PANEL: Config & Inputs (Steps 1, 2, 3) -->
        <Grid Grid.Row="1" Grid.Column="2" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MinHeight="140"/> <!-- Step 1 Card -->
                <RowDefinition Height="Auto"/>                <!-- Row Splitter 1 -->
                <RowDefinition Height="*" MinHeight="250"/>   <!-- Step 2 Card -->
                <RowDefinition Height="Auto"/>                <!-- Step 3 Card -->
            </Grid.RowDefinitions>

            <!-- Step 1: Select AI Models -->
            <Border x:Name="Step1Card" Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" BorderBrush="#FF00BFFF" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border x:Name="Step1PanelBadge" Width="18" Height="18" CornerRadius="9" Background="#FF00BFFF" Margin="0,0,8,0">
                            <TextBlock Text="1" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Step 1: Select AI Models" FontWeight="Bold" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Speech Model -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Speech Model:" VerticalAlignment="Center" FontWeight="SemiBold" Width="100"/>
                        <StackPanel Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="WhisperModelComboBox" SelectionChanged="WhisperModelComboBox_SelectionChanged"/>
                                <Button x:Name="DownloadWhisperButton" Grid.Column="1" Content="Download" Click="DownloadWhisperButton_Click" Margin="8,0,0,0" Padding="8,4" Visibility="Collapsed"/>
                            </Grid>
                            <TextBlock x:Name="WhisperModelStatus" FontSize="10" Foreground="#FF888888" Margin="0,4,0,0"/>
                            <ProgressBar x:Name="WhisperProgressBar" Height="4" Margin="0,4,0,0" Visibility="Collapsed" Foreground="#FF00BFFF" Background="#FF333333"/>
                        </StackPanel>
                    </Grid>

                    <!-- Text Correction Model -->
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Correction Model:" VerticalAlignment="Center" FontWeight="SemiBold" Width="100"/>
                            <CheckBox x:Name="CompareMultipleCheckBox" Grid.Column="1" Content="Compare Multiple Models" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,0" Checked="CompareMultipleCheckBox_Changed" Unchecked="CompareMultipleCheckBox_Changed"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <!-- Single Model Selection -->
                            <StackPanel x:Name="SingleModelSelectionPanel">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="ChatModelComboBox" SelectionChanged="ChatModelComboBox_SelectionChanged"/>
                                    <Button x:Name="DownloadChatButton" Grid.Column="1" Content="Download" Click="DownloadChatButton_Click" Margin="8,0,0,0" Padding="8,4" Visibility="Collapsed"/>
                                </Grid>
                                <TextBlock x:Name="ChatModelStatus" FontSize="10" Foreground="#FF888888" Margin="0,4,0,0"/>
                                <ProgressBar x:Name="ChatProgressBar" Height="4" Margin="0,4,0,0" Visibility="Collapsed" Foreground="#FF00BFFF" Background="#FF333333"/>
                            </StackPanel>

                            <!-- Multiple Models Checklist -->
                            <StackPanel x:Name="MultiModelSelectionPanel" Visibility="Collapsed">
                                <TextBlock Text="Select correction models to compare:" FontSize="10" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <ListBox x:Name="ChatModelsCheckList" Background="#FF1E1E1E" BorderBrush="#FF444444" BorderThickness="1" MinHeight="180" MaxHeight="320" ScrollViewer.VerticalScrollBarVisibility="Auto" VirtualizingPanel.ScrollUnit="Pixel" local:SmoothScrollBehavior.IsEnabled="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsSelected}" Checked="ChatModelCheck_Changed" Unchecked="ChatModelCheck_Changed" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="White" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#FF888888" VerticalAlignment="Center"/>
                                                    <Button Content="Download" Click="DownloadModelInCheckList_Click" Margin="6,0,0,0" Padding="4,2" FontSize="9" Visibility="{Binding DownloadButtonVisibility}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Step 2: Provide Test Input -->
            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#FF333333" Margin="0,0,0,12"/>
            <Border x:Name="Step2Card" Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,12" Opacity="0.5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Border x:Name="Step2PanelBadge" Width="18" Height="18" CornerRadius="9" Background="#FF2D2D2D" Margin="0,0,8,0">
                            <TextBlock x:Name="Step2PanelBadgeText" Text="2" Foreground="#FFAAAAAA" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Step 2: Provide Test Input" FontWeight="Bold" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Unified Input -->
                    <TabControl x:Name="InputTabControl" Grid.Row="1" SelectionChanged="InputTabControl_SelectionChanged">
                        <!-- Microphone Input Tab -->
                        <TabItem Header="🎤 Talk &amp; Record">
                            <Grid Background="{DynamicResource PanelBackgroundBrush}" Margin="0,4,0,0">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <!-- Circular record button -->
                                    <Button x:Name="RecordButton" Width="80" Height="80" Click="RecordButton_Click" HorizontalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Ellipse x:Name="bgCircle" Fill="#FFFF3B30" Stroke="#FF444444" StrokeThickness="2"/>
                                                    <Path x:Name="micIcon" Data="M12,2A3,3 0 0,1 15,5V11A3,3 0 0,1 12,14A3,3 0 0,1 9,11V5A3,3 0 0,1 12,2M19,11C19,14.53 16.39,17.44 13,17.93V21H11V17.93C7.61,17.44 5,14.53 5,11H7A5,5 0 0,0 12,16A5,5 0 0,0 17,11H19Z" Fill="White" Stretch="Uniform" Width="32" Height="32"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bgCircle" Property="Fill" Value="#FFFF453A"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding ElementName=RecordButton, Path=Tag}" Value="Recording">
                                                        <Setter TargetName="bgCircle" Property="Fill" Value="#FF30D158"/>
                                                        <Setter TargetName="micIcon" Property="Data" Value="M18,18H6V6H18V18Z"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <TextBlock x:Name="RecordStatusText" Text="Click button to start recording" FontSize="12" Margin="0,12,0,4" HorizontalAlignment="Center" Foreground="#FF888888"/>
                                    <TextBlock x:Name="RecordingTimerText" Text="00:00" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" HorizontalAlignment="Center" Foreground="White" Visibility="Collapsed"/>
                                    
                                    <!-- Level meter -->
                                    <ProgressBar x:Name="AudioLevelBar" Width="180" Height="6" Value="0" Minimum="0" Maximum="100" Foreground="#FF30D158" Background="#FF333333" BorderBrush="Transparent" Margin="0,8,0,0" Visibility="Collapsed"/>

                                    <!-- Load and Export File utilities -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                                        <Button x:Name="LoadAudioButton" Content="📁 Load WAV" Click="LoadAudioButton_Click" Margin="0,0,8,0" Padding="8,4" Background="#FF2D2D2D" Foreground="White"/>
                                        <Button x:Name="ExportAudioButton" Content="💾 Export Audio" Click="ExportAudioButton_Click" IsEnabled="False" Padding="8,4" Background="#FF2D2D2D" Foreground="White"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- Raw Text Input Tab -->
                        <TabItem Header="✍️ Manual Text Input">
                            <Grid Margin="0,4,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Type or paste sample raw transcription to test text correction formatting:" FontSize="11" Margin="0,0,0,6" Foreground="#FF888888"/>
                                <TextBox x:Name="ManualInputTextBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" local:SmoothScrollBehavior.IsEnabled="True" Text="i think we should check if this works with Gemma and phi. it looks like it is transcribing pretty well."/>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <!-- Target Reference Text for F1 computation -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Target Reference Text (Optional Ground Truth):" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,4"/>
                                <TextBox x:Name="ReferenceInputTextBox" Grid.Row="1" Height="40" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontSize="11" local:SmoothScrollBehavior.IsEnabled="True"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Step 3: Configure & Run Sandbox -->
            <Border x:Name="Step3Card" Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="12" Opacity="0.5">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border x:Name="Step3PanelBadge" Width="18" Height="18" CornerRadius="9" Background="#FF2D2D2D" Margin="0,0,8,0">
                            <TextBlock x:Name="Step3PanelBadgeText" Text="3" Foreground="#FFAAAAAA" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Step 3: Configure &amp; Run Sandbox" FontWeight="Bold" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Base Mode:" VerticalAlignment="Center" FontWeight="SemiBold" Width="80"/>
                        <ComboBox x:Name="ModeComboBox" Grid.Column="1" SelectionChanged="ModeComboBox_SelectionChanged"/>
                    </Grid>

                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <CheckBox x:Name="CleanCheckBox" Content="Clean (Filler words)" IsChecked="True" Margin="0,0,16,6"/>
                        <CheckBox x:Name="ListCheckBox" Content="Format Lists" IsChecked="True" Margin="0,0,16,6"/>
                        <CheckBox x:Name="PunctuationCheckBox" Content="Spoken Punctuation" IsChecked="True" Margin="0,0,0,6"/>
                    </WrapPanel>

                    <Button x:Name="RunPipelineButton" Content="🚀 Run Test Sandbox" Click="RunPipelineButton_Click" Background="#FF2D2D2D" Foreground="White" FontSize="14" Padding="16,10" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Splitter between Center and Right -->
        <GridSplitter Grid.Row="1" Grid.Column="3" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#FF333333" Margin="0,16"/>

         <!-- RIGHT PANEL: Outputs & Visual timing (Step 4) -->
        <Border Grid.Row="1" Grid.Column="4" x:Name="Step4Card" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="16" Opacity="0.5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Step Header -->
                    <RowDefinition Height="*"/>    <!-- TabControl -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <Border x:Name="Step4PanelBadge" Width="18" Height="18" CornerRadius="9" Background="#FF2D2D2D" Margin="0,0,8,0">
                        <TextBlock x:Name="Step4PanelBadgeText" Text="4" Foreground="#FFAAAAAA" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Step 4: Analyze Results &amp; Save Prompt" FontWeight="Bold" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Tab Control -->
                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,4,0,0">
                    <TabItem Header="🔍 Single Run Details">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Raw Output Box -->
                                <RowDefinition Height="2*"/>   <!-- Formatted Output Box -->
                                <RowDefinition Height="1*"/>   <!-- Editable System Prompt -->
                                <RowDefinition Height="Auto"/> <!-- Visual timing metrics -->
                            </Grid.RowDefinitions>

                            <!-- Raw Output Box -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Raw Transcription" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,4"/>
                                <TextBox x:Name="RawOutputTextBox" Grid.Row="1" IsReadOnly="True" Height="65" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" local:SmoothScrollBehavior.IsEnabled="True"/>
                            </Grid>

                            <!-- Formatted Output Box -->
                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Formatted Output" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,4"/>
                                <TextBox x:Name="FormattedOutputTextBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" local:SmoothScrollBehavior.IsEnabled="True"/>
                            </Grid>

                            <!-- Custom system prompt editor -->
                            <Grid Grid.Row="2" Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Custom Mode System Prompt" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,4"/>
                                <TextBox x:Name="SystemPromptTextBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" local:SmoothScrollBehavior.IsEnabled="True"/>
                                <Button x:Name="ApplyToModeButton" Grid.Row="2" Content="Apply edited prompt and options to Mode" Click="ApplyToModeButton_Click" Padding="8,4" FontSize="11" Margin="0,6,0,0" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Performance timing bars -->
                            <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="PERFORMANCE TIMELINE" FontWeight="Bold" Foreground="#FF888888" FontSize="11" Margin="0,0,0,8"/>
                                    
                                    <!-- Horizonal Gantt Timeline using Custom grids and borders -->
                                    <Grid x:Name="TimelineGrid" Height="24" Margin="0,4,0,10" Background="{DynamicResource TimelineBackgroundBrush}">
                                        <Grid.ColumnDefinitions>
                                            <!-- Columns represent proportion of time spent, set programmatically -->
                                            <ColumnDefinition x:Name="WhisperLoadCol" Width="0*"/>
                                            <ColumnDefinition x:Name="WhisperRunCol" Width="0*"/>
                                            <ColumnDefinition x:Name="ChatLoadCol" Width="0*"/>
                                            <ColumnDefinition x:Name="ChatRunCol" Width="0*"/>
                                            <!-- Fill empty remaining space -->
                                            <ColumnDefinition x:Name="TimelineRemainingCol" Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Background="#FF555555" ToolTip="Whisper Model Loading" CornerRadius="2,0,0,2"/>
                                        <Border Grid.Column="1" Background="#FF00BFFF" ToolTip="Whisper Transcription Execution"/>
                                        <Border Grid.Column="2" Background="#FFFFA500" ToolTip="Chat Model Loading"/>
                                        <Border Grid.Column="3" Background="#FF30D158" ToolTip="Chat Model Text Correction Execution" CornerRadius="0,2,2,0"/>
                                    </Grid>

                                    <!-- Text details for durations -->
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                                            <Ellipse Width="8" Height="8" Fill="#FF00BFFF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Transcription: " FontSize="11" Foreground="#FFAAAAAA"/>
                                            <TextBlock x:Name="WhisperTimingsText" Text="0.00s (0.0 words/s)" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock x:Name="WhisperLoadText" Text=" [Load: 0.00s]" FontSize="11" Foreground="#FF888888" Visibility="Collapsed"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                                            <Ellipse Width="8" Height="8" Fill="#FF30D158" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Text Formatting: " FontSize="11" Foreground="#FFAAAAAA"/>
                                            <TextBlock x:Name="ChatTimingsText" Text="0.00s (0.0 char/s)" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock x:Name="ChatLoadText" Text=" [Load: 0.00s]" FontSize="11" Foreground="#FF888888" Visibility="Collapsed"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="Total Pipeline Duration: " FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            <TextBlock x:Name="TotalTimingsText" Text="0.00s" FontSize="12" FontWeight="Bold" Foreground="#FF00BFFF"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="📊 Batch Comparison" x:Name="BatchComparisonTab">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DataGrid x:Name="ComparisonDataGrid" Grid.Row="0" AutoGenerateColumns="False" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#FF1A1A1A" BorderThickness="1" BorderBrush="#FF333333" Foreground="White" RowHeaderWidth="0" IsReadOnly="True" GridLinesVisibility="None" Margin="0,0,0,12">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#FF252525"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#FF333333"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Model" Binding="{Binding ModelName}" Width="1.2*"/>
                                    <DataGridTextColumn Header="Load (s)" Binding="{Binding LoadSecLabel}" Width="0.6*"/>
                                    <DataGridTextColumn Header="Format (s)" Binding="{Binding RunSecLabel}" Width="0.7*"/>
                                    <DataGridTextColumn Header="Total (s)" Binding="{Binding TotalSecLabel}" Width="0.6*"/>
                                    <DataGridTextColumn Header="Speed" Binding="{Binding SpeedLabel}" Width="0.8*"/>
                                    <DataGridTextColumn Header="Sim (F1)" Binding="{Binding SimilarityLabel}" Width="0.7*"/>
                                    <DataGridTemplateColumn Header="Action" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="View" Click="ViewDetails_Click" Padding="6,2" FontSize="10" Margin="2" Background="#FF2D2D2D" Foreground="White"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Selected Model Detail Preview within comparison -->
                            <Border Grid.Row="1" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Selected Output Preview" FontWeight="Bold" Foreground="#FF00BFFF" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox Grid.Row="1" Text="{Binding SelectedItem.FormattedText, ElementName=ComparisonDataGrid, Mode=OneWay}" Height="100" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#FF1E1E1E" Foreground="White" local:SmoothScrollBehavior.IsEnabled="True"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- COMPARISON OVERLAY -->
        <Grid x:Name="ComparisonOverlay" Grid.RowSpan="2" Grid.ColumnSpan="5" Background="{DynamicResource ComparisonOverlayBackgroundBrush}" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Margin="40" Padding="20" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="SIDE-BY-SIDE MODEL COMPARISON" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        <Button Content="✕ Close" Click="CloseComparison_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="8,4"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Comparison Run -->
                        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,8,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" local:SmoothScrollBehavior.IsEnabled="True">
                                <StackPanel>
                                    <TextBlock x:Name="CompLeftLabel" Text="Run A" FontSize="14" FontWeight="Bold" Foreground="#FF00BFFF" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="CompLeftConfig" Text="Whisper / Chat" FontSize="11" Foreground="#FF888888" Margin="0,0,0,12"/>
                                    
                                    <TextBlock Text="Raw Transcription" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,4"/>
                                    <TextBox x:Name="CompLeftRaw" Height="100" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" local:SmoothScrollBehavior.IsEnabled="True"/>

                                    <TextBlock Text="Formatted Output" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,4"/>
                                    <TextBox x:Name="CompLeftFormatted" Height="200" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" local:SmoothScrollBehavior.IsEnabled="True"/>

                                    <TextBlock Text="Performance Timing" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="CompLeftTimings" Text="Transcription: 0s | Formatting: 0s" FontSize="11" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="CompLeftSpeeds" Text="Speed: 0 w/s | 0 c/s" FontSize="11" Foreground="#FF30D158"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" Background="Transparent"/>

                        <!-- Right Comparison Run -->
                        <Border Grid.Column="2" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="8,0,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" local:SmoothScrollBehavior.IsEnabled="True">
                                <StackPanel>
                                    <TextBlock x:Name="CompRightLabel" Text="Run B" FontSize="14" FontWeight="Bold" Foreground="#FF30D158" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="CompRightConfig" Text="Whisper / Chat" FontSize="11" Foreground="#FF888888" Margin="0,0,0,12"/>

                                    <TextBlock Text="Raw Transcription" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,4"/>
                                    <TextBox x:Name="CompRightRaw" Height="100" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" local:SmoothScrollBehavior.IsEnabled="True"/>

                                    <TextBlock Text="Formatted Output" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,4"/>
                                    <TextBox x:Name="CompRightFormatted" Height="200" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12" local:SmoothScrollBehavior.IsEnabled="True"/>

                                    <TextBlock Text="Performance Timing" FontSize="11" FontWeight="SemiBold" Foreground="#FFAAAAAA" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="CompRightTimings" Text="Transcription: 0s | Formatting: 0s" FontSize="11" Foreground="White" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="CompRightSpeeds" Text="Speed: 0 w/s | 0 c/s" FontSize="11" Foreground="#FF30D158"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Button Grid.Row="2" Content="Close Comparison View" Click="CloseComparison_Click" Margin="0,16,0,0" Padding="16,8" HorizontalAlignment="Right" Background="#FF2A2A2A"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
