<Window x:Class="Prompter.Views.SnippetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Snippet"
        Width="520"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="#FFEEEEEE">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Trigger Phrase" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Text="What you say to activate this snippet. Keep it short and unique." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
            <TextBox x:Name="TriggerTextBox" Padding="8,6"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Expansion Text" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Text="The full text that will be inserted when the trigger is recognized. Use {Enter}, {Tab}, etc. for special keys." FontSize="11" Foreground="#FF888888" Margin="0,0,0,8"/>
            <TextBox Grid.Row="2" x:Name="ExpansionTextBox" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="8,6" Margin="0,0,0,8"/>
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="KeyComboBox" Grid.Column="0" Padding="6,4" Margin="0,0,8,0"/>
                <Button x:Name="InsertKeyButton" Grid.Column="1" Content="Insert" Width="80" Click="InsertKeyButton_Click"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Save" Width="90" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
