<Window x:Class="Prompter.Views.CustomModelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Model Manager"
        Width="980"
        Height="720"
        MinWidth="700"
        MinHeight="500"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="#FFEEEEEE">

    <Window.Resources>
        <!-- Sidebar Radio Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF999999"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="GroupName" Value="Modes"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF222222"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#FF2A2A2A"/>
                                <Setter Property="Foreground" Value="#FF00BFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF00BFFF"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="3,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="MODEL SETTINGS" FontWeight="Bold" Foreground="#FF666666" FontSize="11" Margin="24,24,0,12"/>
                <StackPanel Grid.Row="1" Margin="12,0,12,0">
                    <RadioButton x:Name="WhisperModeButton" Content="🎤 Speech Models (Whisper)" IsChecked="True" Checked="ModeButton_Checked" Style="{StaticResource SidebarButtonStyle}"/>
                    <RadioButton x:Name="LlmModeButton" Content="✍️ Text Models (LLMs)" Checked="ModeButton_Checked" Style="{StaticResource SidebarButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Main Panel -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tabs for Model Management -->
            <TabControl x:Name="ManagerTabControl" Grid.Row="0">
                <!-- TAB 1: Downloaded Models -->
                <TabItem Header="Downloaded Models">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="DownloadedListView" Grid.Row="0" Margin="0,0,0,12" GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                            <ListView.View>
                                <GridView x:Name="DownloadedGridView">
                                    <!-- Populated programmatically based on active type -->
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DeleteModelButton" Content="Delete File/Folder" Click="DeleteModelButton_Click" Margin="0,0,8,0" Width="140"/>
                            <Button x:Name="RefreshDownloadedButton" Content="Refresh List" Click="RefreshDownloadedButton_Click" Width="120"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- TAB 2: Curated Models -->
                <TabItem Header="Recommended Models">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="RecommendedListView" Grid.Row="0" Margin="0,0,0,12" GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Model Name" Width="180">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" ToolTip="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Description" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Description}" ToolTip="{Binding Description}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Size" Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SizeDescription}" ToolTip="{Binding SizeDescription}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Status" Width="90">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Status}" ToolTip="{Binding Status}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DownloadCuratedButton" Content="Download Selected" Click="DownloadCuratedButton_Click" Width="180"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- TAB 3: Browse GGUF Hub -->
                <TabItem x:Name="HubTabItem" Header="Browse GGUF Hub">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="1. Search and select a repository" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="HubSearchTextBox" Width="320" VerticalContentAlignment="Center" Padding="8,6" KeyDown="HubSearchTextBox_KeyDown"/>
                                <Button x:Name="HubSearchButton" Content="Search" Click="HubSearchButton_Click" Margin="8,0,0,0" Padding="12,6"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <ListView x:Name="HubRepoListView" SelectionChanged="HubRepoListView_SelectionChanged" GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Model" Width="220">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}" ToolTip="{Binding RepoId}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Downloads" Width="90">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DownloadsText}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Tags" Width="160">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TagsText}" TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="HF" Padding="8,2" FontSize="11" Click="OpenHuggingFace_Click" Tag="{Binding RepoId}" ToolTip="Open on Hugging Face" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBlock x:Name="HubRepoEmptyText" Text="No repositories found. Try a different search term." Foreground="#FF888888" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                        </Grid>

                        <TextBlock Grid.Row="2" Text="2. Select a GGUF file to download" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>

                        <Grid Grid.Row="3" Margin="0,0,0,8">
                            <ListView x:Name="HubFileListView" SelectionChanged="HubFileListView_SelectionChanged" GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="File" Width="260">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Size" Width="90">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SizeText}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBlock x:Name="HubFileEmptyText" Text="Select a repository above to see its GGUF files." Foreground="#FF888888" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
                        </Grid>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="HubDownloadButton" Content="Download Selected GGUF" Click="HubDownloadButton_Click" Width="200" Padding="12,6"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- TAB 4: Advanced Download -->
                <TabItem Header="Advanced Search &amp; Download">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="1. Search and select a repository" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="AdvancedSearchTextBox" Width="320" VerticalContentAlignment="Center" Padding="8,6" KeyDown="AdvancedSearchTextBox_KeyDown"/>
                                <Button x:Name="AdvancedSearchButton" Content="Search" Click="AdvancedSearchButton_Click" Margin="8,0,0,0" Padding="12,6"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <ListView x:Name="AdvancedRepoListView" SelectionChanged="AdvancedRepoListView_SelectionChanged" GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Model" Width="220">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DisplayName}" ToolTip="{Binding RepoId}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Downloads" Width="90">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DownloadsText}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Tags" Width="160">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TagsText}" TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="" Width="80">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="HF" Padding="8,2" FontSize="11" Click="OpenHuggingFace_Click" Tag="{Binding RepoId}" ToolTip="Open on Hugging Face" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBlock x:Name="AdvancedRepoEmptyText" Text="Enter a search term to find repositories." Foreground="#FF888888" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
                        </Grid>

                        <TextBlock Grid.Row="2" Text="2. Select a file to download" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>

                        <Grid Grid.Row="3" Margin="0,0,0,8">
                            <ListView x:Name="AdvancedFileListView" SelectionChanged="AdvancedFileListView_SelectionChanged" GridViewColumnHeader.Click="GridViewColumnHeader_Click">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="File" Width="260">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Size" Width="90">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding SizeText}" />
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <TextBlock x:Name="AdvancedFileEmptyText" Text="Select a repository above to see its files." Foreground="#FF888888" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible"/>
                        </Grid>

                        <StackPanel Grid.Row="4" Margin="0,0,0,8">
                            <TextBlock Text="Hugging Face Repository ID" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="RepoIdTextBox" Text="distil-whisper/distil-large-v3-ggml" Margin="0,0,0,8"/>

                            <StackPanel x:Name="FileNameContainer">
                                <TextBlock Text="Model File Name (.bin)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="FileNameTextBox" Text="ggml-distil-large-v3.bin" Margin="0,0,0,8"/>
                            </StackPanel>

                            <StackPanel x:Name="LlmDownloadInfoContainer" Visibility="Collapsed" Margin="0,0,0,8">
                                <TextBlock Text="Model Subdirectory (Optional)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox x:Name="LlmSubdirTextBox" Text="" Margin="0,0,0,4"/>
                                <TextBlock Text="Leave empty to auto-detect the ONNX model directory in the repository." FontSize="11" Foreground="#FF888888"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DownloadAdvancedButton" Content="Download Custom Model" Click="DownloadAdvancedButton_Click" Width="220" Padding="12,8"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Global Status and Progress Bar -->
            <Grid Grid.Row="1" Margin="4,16,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ProgressStatusTextBlock" Grid.Row="0" Grid.Column="0" Text="Ready" Margin="0,0,0,6" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="ProgressPctTextBlock" Grid.Row="0" Grid.Column="1" Text="" Margin="0,0,0,6" FontWeight="SemiBold"/>

                <ProgressBar x:Name="DownloadProgressBar" Grid.Row="1" Grid.ColumnSpan="2" Height="12" Minimum="0" Maximum="100" Value="0" Foreground="#FF00BFFF" Background="#FF333333" BorderBrush="Transparent"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
