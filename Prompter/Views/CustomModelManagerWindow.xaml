<Window x:Class="Prompter.Views.CustomModelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Model Manager"
        Width="820"
        Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF151515"
        Foreground="#FFEEEEEE">

    <Window.Resources>
        <!-- Style inheritance from parent window design style -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Variable, Roboto"/>
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="#FF151515"/>
            <Setter Property="Foreground" Value="#FF888888"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0"
                                Margin="0,0,4,-1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="contentPresenter" ContentSource="Header" Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#FF252525"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FF00BFFF"/>
                                <Setter Property="Background" Value="#FF1E1E1E"/>
                                <Setter Property="BorderBrush" Value="#FF333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF00BFFF"/>
                                <Setter Property="BorderBrush" Value="#FF00BFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF008B8B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF555555"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FF00BFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#FF151515"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="#FF252525" BorderThickness="0,0,0,1" Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF222222"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF2A2A2A"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF00BFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="BorderBrush" Value="#FF333333"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="headerBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="headerBorder" Property="Background" Value="#FF2A2A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Radio Button Style -->
        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF999999"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="GroupName" Value="Modes"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF222222"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#FF2A2A2A"/>
                                <Setter Property="Foreground" Value="#FF00BFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF00BFFF"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="3,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#FF111111" BorderBrush="#FF252525" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="MODEL SETTINGS" FontWeight="Bold" Foreground="#FF666666" FontSize="11" Margin="24,24,0,12"/>
                <StackPanel Grid.Row="1" Margin="12,0,12,0">
                    <RadioButton x:Name="WhisperModeButton" Content="🎤 Speech Models (Whisper)" IsChecked="True" Checked="ModeButton_Checked" Style="{StaticResource SidebarButtonStyle}"/>
                    <RadioButton x:Name="LlmModeButton" Content="✍️ Text Models (LLMs)" Checked="ModeButton_Checked" Style="{StaticResource SidebarButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Main Panel -->
        <Grid Grid.Column="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tabs for Model Management -->
            <TabControl Grid.Row="0">
                <!-- TAB 1: Downloaded Models -->
                <TabItem Header="Downloaded Models">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="DownloadedListView" Grid.Row="0" Margin="0,0,0,12">
                            <ListView.View>
                                <GridView x:Name="DownloadedGridView">
                                    <!-- Populated programmatically based on active type -->
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DeleteModelButton" Content="Delete File/Folder" Click="DeleteModelButton_Click" Margin="0,0,8,0" Width="140"/>
                            <Button x:Name="RefreshDownloadedButton" Content="Refresh List" Click="RefreshDownloadedButton_Click" Width="120"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- TAB 2: Curated Models -->
                <TabItem Header="Recommended Models">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ListView x:Name="RecommendedListView" Grid.Row="0" Margin="0,0,0,12">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Model Name" Width="180">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" ToolTip="{Binding DisplayName}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Description" Width="200">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Description}" ToolTip="{Binding Description}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Size" Width="80">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SizeDescription}" ToolTip="{Binding SizeDescription}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Status" Width="90">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Status}" ToolTip="{Binding Status}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DownloadCuratedButton" Content="Download Selected" Click="DownloadCuratedButton_Click" Width="180"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- TAB 3: Advanced Download -->
                <TabItem Header="Advanced Search &amp; Download">
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock x:Name="AdvancedTitleTextBlock" Text="Download any GGML Whisper model from Hugging Face" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,4"/>
                        <TextBlock x:Name="AdvancedDescTextBlock" Text="Enter the repository ID and file name of the model to download. Ensure it is in the GGML format (.bin)." FontSize="11" Foreground="#FF888888" Margin="0,0,0,16" TextWrapping="Wrap"/>

                        <TextBlock Text="Hugging Face Repository ID" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="RepoIdTextBox" Text="distil-whisper/distil-large-v3-ggml" Margin="0,0,0,16"/>

                        <StackPanel x:Name="FileNameContainer">
                            <TextBlock Text="Model File Name (.bin)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="FileNameTextBox" Text="ggml-distil-large-v3.bin" Margin="0,0,0,24"/>
                        </StackPanel>

                        <StackPanel x:Name="LlmDownloadInfoContainer" Visibility="Collapsed" Margin="0,0,0,24">
                            <TextBlock Text="Model Subdirectory (Optional - e.g. onnx/cpu_and_mobile/cpu-int4-rtn-block-32)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="LlmSubdirTextBox" Text="" Margin="0,0,0,8"/>
                            <TextBlock Text="Leave empty to auto-detect the ONNX model directory in the repository." FontSize="11" Foreground="#FF888888"/>
                        </StackPanel>

                        <Button x:Name="DownloadAdvancedButton" Content="Download Custom Model" Click="DownloadAdvancedButton_Click" HorizontalAlignment="Left" Width="220" Padding="12,8"/>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <!-- Global Status and Progress Bar -->
            <Grid Grid.Row="1" Margin="4,16,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="ProgressStatusTextBlock" Grid.Row="0" Grid.Column="0" Text="Ready" Margin="0,0,0,6" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="ProgressPctTextBlock" Grid.Row="0" Grid.Column="1" Text="" Margin="0,0,0,6" FontWeight="SemiBold"/>

                <ProgressBar x:Name="DownloadProgressBar" Grid.Row="1" Grid.ColumnSpan="2" Height="12" Minimum="0" Maximum="100" Value="0" Foreground="#FF00BFFF" Background="#FF333333" BorderBrush="Transparent"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
